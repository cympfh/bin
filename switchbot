@click.argument("data", type=str, default="")
def send(device_id: str, data: Any):
    if data:
        data_json = json.loads(data)
    else:
        data_json = {}
    res = Switchbot().post(f"/v1.1/devices/{device_id}/commands", data_json)
    print(json.dumps(res))


