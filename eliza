#!/usr/bin/env python3

import json

import click
import requests

PORT = 9096


def get_host() -> str:
    try:
        requests.get(f"http://localhost:{PORT}/eliza/api/health", timeout=2)
        return "localhost"
    except Exception:
        resp = requests.get("http://s.cympfh.cc/journal/cympfh/ip?tail=1")
        data = resp.json()
        return data[-1]["data"]["ip"]


class DefaultGroup(click.Group):
    """未知のサブコマンドを chat にフォールバックするグループ"""

    def resolve_command(self, ctx, args):
        try:
            return super().resolve_command(ctx, args)
        except click.UsageError:
            return "chat", self.commands["chat"], args


@click.group(cls=DefaultGroup, invoke_without_command=True)
@click.pass_context
def cli(ctx: click.Context):
    """Eliza chat CLI"""
    if ctx.invoked_subcommand is None:
        click.echo(ctx.get_help())


@cli.command()
def summary():
    """サマリーを作成"""
    host = get_host()
    resp = requests.post(f"http://{host}:{PORT}/eliza/api/summary")
    click.echo(json.dumps(resp.json(), indent=2, ensure_ascii=False))


@cli.command()
@click.argument("message", nargs=-1, required=True)
def chat(message: tuple[str, ...]):
    """チャットメッセージを送信"""
    host = get_host()
    content = " ".join(message)
    payload = {
        "use_memory": True,
        "detect_sleep": False,
        "max_loop": 5,
        "messages": [{"role": "user", "content": content}],
    }
    resp = requests.post(f"http://{host}:{PORT}/eliza/api/chat", json=payload)
    click.echo(json.dumps(resp.json(), indent=2, ensure_ascii=False))


if __name__ == "__main__":
    cli()
