#!/bin/bash

TITLE=
SUBTITLE=
MESSAGE=
ICON=$HOME/bin/img/osaka.jpg
SOUND=0

usage() {
  cat << USAGE
NAME
    notify -- my wrapper for notify-send (ubuntu), terminal-notifier (OSX)

SYNOPSIS
    notify [ --title <string> ] [ --subtitle <string> ] [ --icon <path or URL> ] [ --sound ] <string>
USAGE
  exit 0
}

nopackage() {
    echo "Please install notify-send or terminal-notifier. Or implement"
    exit 1
}

is_wsl() {
    grep -qi microsoft /proc/version 2>/dev/null
}

install_wsl_notify_send() {
    local install_dir="$HOME/.local/bin"
    local zip_url="https://github.com/stuartleeks/wsl-notify-send/releases/download/v0.1.871612270/wsl-notify-send_windows_386.zip"
    local tmp_zip="/tmp/wsl-notify-send.zip"
    mkdir -p "$install_dir"
    echo "Installing wsl-notify-send..."
    if command -v wget >/dev/null; then
        wget -q -O "$tmp_zip" "$zip_url"
    else
        curl -sL -o "$tmp_zip" "$zip_url"
    fi
    unzip -o -j "$tmp_zip" wsl-notify-send.exe -d "$install_dir"
    rm -f "$tmp_zip"
}

# args
while [ -n "$1" ]; do
    case $1 in
        --title | -title )
            TITLE=$2
            shift 2
            ;;
        --subtitle | --sub | -subtitle | -sub )
            SUBTITLE=$2
            shift 2
            ;;
        --icon | -icon )
            ICON=$2
            shift 2
            ;;
        --help | -h )
            usage
            ;;
        --sound | -S )
            SOUND=1
            shift
            ;;
        * )
            MESSAGE=$1
            shift 1
            ;;
    esac
done

# exec notify
if command -v terminal-notifier >/dev/null; then
    terminal-notifier -title "${TITLE}" -subtitle "${SUBTITLE}" -message "${MESSAGE}" -appIcon "${ICON}"
elif is_wsl; then
    if ! command -v wsl-notify-send.exe >/dev/null; then
        install_wsl_notify_send
    fi
    BODY="${MESSAGE}"
    if [ -n "${SUBTITLE}" ]; then
        BODY="${SUBTITLE}: ${MESSAGE}"
    fi
    HEADER="${TITLE:-notification}"
    wsl-notify-send.exe --category "${HEADER}" "${BODY}"
elif command -v notify-send >/dev/null; then
    if [ -n "${SUBTITLE}" ]; then
        TITLE="${TITLE} - ${SUBTITLE}"
    fi
    if [ -z "${TITLE}" ]; then
        TITLE="notification"
    fi
    notify-send "${TITLE}" "${MESSAGE}" --icon "${ICON}"
else
    nopackage
fi

# --sound
if [ $SOUND -eq 1 ]; then
    SND_PATH=/tmp/notification.sound.mp3
    if [ ! -f $SND_PATH ]; then
        wget -O $SND_PATH https://notificationsounds.com/soundfiles/a86c450b76fb8c371afead6410d55534/file-sounds-1108-slow-spring-board.mp3
    fi
    mplayer -quiet $SND_PATH >/dev/null 2>&1 &
fi
