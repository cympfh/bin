#!/bin/bash

TITLE=
SUBTITLE=
MESSAGE=
ICON=$HOME/bin/img/osaka_1_4.jpg
SOUND=0

usage() {
  cat << USAGE
NAME
    notify -- my wrapper for notify-send (ubuntu), terminal-notifier (OSX), BurntToast (WSL)

SYNOPSIS
    notify [ --title <string> ] [ --subtitle <string> ] [ --icon <path or URL> ] [ --sound ] <string>
USAGE
  exit 0
}

nopackage() {
    echo "Please install notify-send or terminal-notifier. Or implement"
    exit 1
}

is_wsl() {
    grep -qi microsoft /proc/version 2>/dev/null
}

burnttoast_notify() {
    local header="$1"
    local body="$2"
    local icon="$3"
    # Escape single quotes for PowerShell single-quoted strings
    header="${header//\'/\'\'}"
    body="${body//\'/\'\'}"
    local ps_cmd="Import-Module BurntToast -ErrorAction Stop; New-BurntToastNotification -Text '${header}', '${body}'"
    if [ -n "${icon}" ] && [ -f "${icon}" ]; then
        local win_icon
        win_icon=$(wslpath -w "${icon}" 2>/dev/null)
        if [ -n "${win_icon}" ]; then
            win_icon="${win_icon//\'/\'\'}"
            ps_cmd="Import-Module BurntToast -ErrorAction Stop; New-BurntToastNotification -Text '${header}', '${body}' -AppLogo '${win_icon}'"
        fi
    fi
    if ! powershell.exe -Command "${ps_cmd}" 2>/dev/null; then
        echo "Error: BurntToast not found." >&2
        echo "Install with: powershell.exe -Command \"Install-Module BurntToast -Force\"" >&2
        exit 1
    fi
}

# args
while [ -n "$1" ]; do
    case $1 in
        --title | -title )
            TITLE=$2
            shift 2
            ;;
        --subtitle | --sub | -subtitle | -sub )
            SUBTITLE=$2
            shift 2
            ;;
        --icon | -icon )
            ICON=$2
            shift 2
            ;;
        --help | -h )
            usage
            ;;
        --sound | -S )
            SOUND=1
            shift
            ;;
        * )
            MESSAGE=$1
            shift 1
            ;;
    esac
done

# exec notify
if command -v terminal-notifier >/dev/null; then
    terminal-notifier -title "${TITLE}" -subtitle "${SUBTITLE}" -message "${MESSAGE}" -appIcon "${ICON}"
elif is_wsl; then
    BODY="${MESSAGE}"
    if [ -n "${SUBTITLE}" ]; then
        BODY="${SUBTITLE}: ${MESSAGE}"
    fi
    HEADER="${TITLE:-notification}"
    burnttoast_notify "${HEADER}" "${BODY}" "${ICON}"
elif command -v notify-send >/dev/null; then
    if [ -n "${SUBTITLE}" ]; then
        TITLE="${TITLE} - ${SUBTITLE}"
    fi
    if [ -z "${TITLE}" ]; then
        TITLE="notification"
    fi
    notify-send "${TITLE}" "${MESSAGE}" --icon "${ICON}"
else
    nopackage
fi

# --sound
if [ $SOUND -eq 1 ]; then
    SND_PATH=/tmp/notification.sound.mp3
    if [ ! -f $SND_PATH ]; then
        wget -O $SND_PATH https://notificationsounds.com/soundfiles/a86c450b76fb8c371afead6410d55534/file-sounds-1108-slow-spring-board.mp3
    fi
    mplayer -quiet $SND_PATH >/dev/null 2>&1 &
fi
